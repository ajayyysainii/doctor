# Copy to .env and fill values (see README)

DB_URI="mongodb+srv://USER:PASS@cluster.mongodb.net/doctor"
NEXT_PUBLIC_SITE_URL="https://www.orthodrskpalsania.com"

# Razorpay (server + public key id for Checkout)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# Agora
AGORA_APP_ID=""
AGORA_APP_CERTIFICATE=""
NEXT_PUBLIC_AGORA_APP_ID=""

# Twilio WhatsApp — must be real E.164 (no placeholders). Sandbox: join sandbox, then use Twilio’s WhatsApp From number.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
TWILIO_ADMIN_WHATSAPP_TO="whatsapp:+919876543210"

# Fixed consultation fee (INR whole rupees)
CONSULTATION_FEE_INR="500"

# Admin dashboard (shared password)
ADMIN_PASSWORD="change-me-in-production"

# Nodemailer / SMTP (for email notifications with teleconsultation link)
# Gmail example: use an App Password (not your account password)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM_NAME="Dr SK Palsania Clinic"
ADMIN_EMAIL="doctor@example.com"


##done

# Amazon S3 — image uploads for blog (featured images + inline editor images)
AWS_REGION="ap-south-1"
AWS_S3_BUCKET="your-bucket-name"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
